if (cachedUser?.mode === 'gaming') {
  document.body.classList.add('gaming');
  document.getElementById('themeToggle').innerText = 'LUMOS';
}

if (cachedUser?.mode === 'gaming') {
  document.querySelectorAll('.scan-icon').forEach(icon => {
    icon.style.filter = 'invert(1)';
  });
} else {
  document.querySelectorAll('.scan-icon').forEach(icon => {
